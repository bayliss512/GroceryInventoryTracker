@page
@model ConfigurationModel
@{
	ViewData["Title"] = "Configuration";
}

<div class="configuration-page">
	<header class="page-header mb-4">
		<h1>Configuration</h1>
		<p class="lead">Database Management</p>
	</header>

	@if (!string.IsNullOrEmpty(Model.SuccessMessage))
	{
		<div class="alert alert-success alert-dismissible fade show" role="alert">
			<strong>Success!</strong> @Model.SuccessMessage
			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
		</div>
	}

	@if (!string.IsNullOrEmpty(Model.ErrorMessage))
	{
		<div class="alert alert-danger alert-dismissible fade show" role="alert">
			<strong>Error:</strong> @Model.ErrorMessage
			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
		</div>
	}

	<section class="database-management">
		<div class="card">
			<div class="card-header bg-body-tertiary">
				<h5 class="mb-0">Database Management</h5>
			</div>
			<div class="card-body">
				<p class="text-muted">Use these tools to manage your inventory database.</p>

				<div class="row g-3">
					<div class="col-md-6">
						<form method="post" asp-page-handler="InitializeDatabase">
							<div class="card border-success">
								<div class="card-body">
									<h6 class="card-title">Initialize Database</h6>
									<p class="card-text text-muted small">Create database tables and populate with seed data.</p>
									<button type="submit" class="btn btn-success">
										<svg class="icon"><use href="#icon-plus"></use></svg> Initialize Database
									</button>
								</div>
							</div>
						</form>
					</div>

					<div class="col-md-6">
						<form method="post" asp-page-handler="DeleteDatabase" data-confirm="Are you sure you want to delete the database? This action cannot be undone.">
							<div class="card border-danger">
								<div class="card-body">
									<h6 class="card-title text-danger">Delete Database</h6>
									<p class="card-text text-muted small">Permanently delete all database tables and data.</p>
									<button type="submit" class="btn btn-danger">
										<svg class="icon"><use href="#icon-trash"></use></svg> Delete Database
									</button>
								</div>
							</div>
						</form>
					</div>

					<div class="col-md-6">
						<form method="post" asp-page-handler="GenerateRandomShipment">
							<div class="card border-info">
								<div class="card-body">
									<h6 class="card-title text-info">Generate Random Shipment</h6>
									<p class="card-text text-muted small">Create a random shipment with a random product and quantity.</p>
									<button type="submit" class="btn btn-info">
										<svg class="icon"><use href="#icon-truck"></use></svg> Generate Shipment
									</button>
								</div>
							</div>
						</form>
					</div>

					<div class="col-md-6">
						<div class="card border-primary generate-configurable-shipment" style="cursor:pointer;">
							<div class="card-body">
								<h6 class="card-title text-primary">Generate Configurable Shipment</h6>
								<p class="card-text text-muted small">Create a shipment with user provided qualities.</p>
								<button type="button" class="btn btn-primary">
									<svg class="icon"><use href="#icon-truck"></use></svg> Generate Shipment
								</button>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="database-schema mt-5">
		<div class="card">
			<div class="card-header bg-body-tertiary">
				<h5 class="mb-0">Database Schema Information</h5>
			</div>
			<div class="card-body">
				<p class="text-muted">When initialized, your database contains:</p>

				<div class="row g-4">
					<div class="col-md-6">
						<h6 class="fw-bold">Categories Table</h6>
						<ul class="small">
							<li><strong>Name:</strong> Category display name</li>
							<li><strong>21 seed categories:</strong> Produce, Meat &amp; Seafood, Dairy &amp; Refrigerated, Bakery, Frozen Foods, and more</li>
						</ul>
					</div>
					<div class="col-md-6">
						<h6 class="fw-bold">Products Table</h6>
						<ul class="small">
							<li><strong>Name:</strong> Product display name</li>
							<li><strong>CategoryId:</strong> The category the product belongs to</li>
							<li><strong>ImagePath:</strong> Product image in local storage</li>
							<li><strong>288 seed products</strong> across all 21 categories</li>
						</ul>
					</div>
					<div class="col-md-6">
						<h6 class="fw-bold">Shipments Table</h6>
						<ul class="small">
							<li><strong>Tracks incoming inventory:</strong> When products arrive at the store</li>
							<li><strong>ShipmentNumber:</strong> Unique identifier for the shipment</li>
							<li><strong>ExpirationDate:</strong> When the shipment expires</li>
							<li><strong>Quantity:</strong> How many units in this shipment</li>
							<li><strong>Location:</strong> "InStorage" (warehouse) or "OnFloor" (sales floor)</li>
							<li><strong>Seed shipments:</strong> 2-3 for each of the first 50 products</li>
						</ul>
					</div>
					<div class="col-md-6">
						<h6 class="fw-bold">Users Table</h6>
						<ul class="small">
							<li><strong>Username:</strong> Unique login name (max 64 characters)</li>
							<li><strong>PasswordHash:</strong> Salted PBKDF2 hash &mdash; the plaintext password is never stored</li>
							<li><strong>IconSvg:</strong> Random identicon generated at sign-up</li>
							<li><strong>ProfileImagePath:</strong> Optional uploaded profile picture (stored in local image storage)</li>
							<li><strong>CreatedAt:</strong> When the account was created</li>
							<li><strong>No seed users:</strong> Accounts are created via the Login popup</li>
						</ul>
					</div>
				</div>

				<div class="alert alert-info mt-3 small">
					<strong>ℹ️ Inventory Levels:</strong><br>
					- <strong>QuantityStored:</strong> Items in the warehouse/storage area (the "back" inventory)<br>
					- <strong>QuantityOnSalesFloor:</strong> Items currently on the store shelves for customers (the "front" inventory)<br>
					Both are calculated by summing each product's shipments by Location &mdash; together they show the total available inventory.
				</div>
			</div>
		</div>
	</section>

	<!-- Configurable Shipment Modal -->
	<div id="productModal" class="custom-modal" role="dialog" aria-hidden="true">
		<div class="custom-modal-dialog">
			<div class="custom-modal-content">
				<div class="custom-modal-header">
					<h5 id="productModalTitle">Generate Configurable Shipment</h5>
					<button id="productModalClose" class="btn-close" aria-label="Close">&times;</button>
				</div>
				<div class="custom-modal-body" id="productModalBody">
					<form method="post" asp-page-handler="GenerateConfigurableShipment">
						<div class="mb-3">
							<label asp-for="Input.ProductId" class="form-label">Product</label>
							<select asp-for="Input.ProductId" class="form-select">
								<option value="">-- Random --</option>
								@foreach (var p in Model.Products)
								{
									<option value="@p.Id">@p.Name</option>
								}
							</select>
						</div>
						<div class="mb-3">
							<label asp-for="Input.Quantity" class="form-label">Quantity</label>
							<input asp-for="Input.Quantity" type="number" min="1" class="form-control" placeholder="Leave blank for random quantity" />
						</div>
						<div class="mb-3">
							<label asp-for="Input.ExpirationDate" class="form-label">Expiration Date</label>
							<input asp-for="Input.ExpirationDate" type="date" class="form-control" placeholder="Leave blank for random date" />
						</div>
						<div class="mb-3">
							<label asp-for="Input.ShipmentNumber" class="form-label">Shipment Number</label>
							<input asp-for="Input.ShipmentNumber" type="text" class="form-control" placeholder="Leave blank to auto-generate" />
						</div>
						<button type="submit" class="btn btn-primary">
							<svg class="icon"><use href="#icon-truck"></use></svg> Create Shipment
						</button>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>

<script src="~/js/addShipment.js"></script>
