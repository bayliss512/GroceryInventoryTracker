@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="inventory-page">
    <header class="mb-4">
        <h1>Grocery Inventory Tracker</h1>
        <p class="lead">Employee Inventory Dashboard</p>
    </header>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <strong>Notice:</strong> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <section class="search-area mb-3">
        <form method="get">
            <div class="input-group">
                <input name="Search" value="@Model.Search" type="text" class="form-control" placeholder="Search products or categories..." aria-label="Search" />
                <button class="btn btn-primary" type="submit">Search</button>
            </div>
        </form>
        <div class="mt-2 text-muted">
            @if (Model.TotalCount > 0)
            {
                <small>@Model.TotalCount product(s) found.</small>
            }
            else
            {
                <small>No products found.</small>
            }
        </div>
    </section>

    <section class="product-list">
        @if (Model.Products?.Any() != true)
        {
            <div class="empty-state">
                @if (string.IsNullOrEmpty(Model.Search))
                {
                    <p class="text-muted">No products available. Use the Configuration page to initialize the database with sample data.</p>
                }
                else
                {
                    <p class="text-muted">No products found matching your search. Try a different search term.</p>
                }
            </div>
        }
        else
        {
            @foreach (var group in Model.Products.GroupBy(p => p.Category?.Name ?? "Uncategorized"))
            {
                <div class="category-section">
                    <h3 class="category-header">@group.Key</h3>
                    <div class="product-grid">
                        @foreach (var p in group)
                        {
                            <div class="product-card" data-product-id="@p.Id" data-product-name="@p.Name" style="cursor:pointer;">
                                <div class="product-image-container">
                                    <img src="@p.ImagePath" alt="@p.Name" class="product-image" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22400%22 height=%22400%22%3E%3Crect fill=%22%23e9ecef%22 width=%22400%22 height=%22400%22/%3E%3Ctext x=%2250%25%22 y=%2250%25%22 font-size=%2220%22 fill=%22%236c757d%22 text-anchor=%22middle%22 dy=%22.3em%22%3EImage unavailable%3C/text%3E%3C/svg%3E'" />
                                </div>
                                <div class="product-body">
                                    <h4 class="product-name">@p.Name</h4>
                                    <p class="product-category">@group.Key</p>
                                    <div class="product-quantities">
                                        <span class="quantity-badge stored">
                                            <strong>In Storage:</strong> @p.QuantityStored
                                        </span>
                                        <span class="quantity-badge shelves">
                                            <strong>On Sales Floor:</strong> @p.QuantityOnSalesFloor
                                        </span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="pagination-nav">
                <ul class="pagination">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="?Search=@Model.Search&Page=@(Model.CurrentPage - 1)">Previous</a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="?Search=@Model.Search&Page=@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="?Search=@Model.Search&Page=@(Model.CurrentPage + 1)">Next</a>
                    </li>
                </ul>
            </nav>
        }
    </section>

    <!-- Product Modal -->
    <div id="productModal" class="custom-modal" role="dialog" aria-hidden="true">
        <div class="custom-modal-dialog">
            <div class="custom-modal-content">
                <div class="custom-modal-header">
                    <h5 id="productModalTitle">Product Details</h5>
                    <button id="productModalClose" class="btn-close" aria-label="Close">×</button>
                </div>
                <div class="custom-modal-body" id="productModalBody">
                    <!-- Shipment details loaded dynamically -->
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/js/inventory.js"></script>
