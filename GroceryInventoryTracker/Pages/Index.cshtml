@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="inventory-page">
    <header class="mb-4">
        <h1>Grocery Inventory Tracker</h1>
        <p class="lead">Employee Inventory Dashboard</p>
    </header>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">h
            <strong>Notice:</strong> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <section class="search-area mb-3">
        <form method="get" class="filter-form">
            <div class="filter-row">
                <select name="CategoryId" class="form-select" aria-label="Category" onchange="this.form.submit()">
                    <option value="">All Categories</option>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option>
                    }
                </select>
                <select name="SupplierId" class="form-select" aria-label="Supplier" onchange="this.form.submit()">
                    <option value="">All Suppliers</option>
                    @foreach (var s in Model.Suppliers)
                    {
                        <option value="@s.Id" selected="@(Model.SupplierId == s.Id)">@s.Name</option>
                    }
                </select>
                <select name="ExpirationFilter" class="form-select" aria-label="Expiration" onchange="this.form.submit()">
                    <option value="" selected="@(string.IsNullOrEmpty(Model.ExpirationFilter))">All Expirations</option>
                    <option value="ExpiringSoon" selected="@(Model.ExpirationFilter == "ExpiringSoon")">Expiring Soon (7 days)</option>
                    <option value="Expired" selected="@(Model.ExpirationFilter == "Expired")">Expired</option>
                </select>
                <select name="SortBy" class="form-select" aria-label="Sort by" onchange="this.form.submit()">
                    <option value="" selected="@(string.IsNullOrEmpty(Model.SortBy) || Model.SortBy == "Name")">Sort: Name</option>
                    <option value="Quantity" selected="@(Model.SortBy == "Quantity")">Sort: Quantity</option>
                    <option value="Expiration" selected="@(Model.SortBy == "Expiration")">Sort: Expiration</option>
                    <option value="RecentlyUpdated" selected="@(Model.SortBy == "RecentlyUpdated")">Sort: Recently Updated</option>
                </select>
            </div>
            <div class="input-group search-input-group">
                <input id="searchInput" name="Search" value="@Model.Search" type="text" class="form-control" placeholder="Search products or categories..." aria-label="Search" />
                <button class="btn btn-primary" type="submit">Search</button>
            </div>
        </form>
        <div class="mt-2 text-muted">
            @if (Model.TotalCount > 0)
            {
                <small>@Model.TotalCount product(s) found.</small>
            }
            else
            {
                <small>No products found.</small>
            }
        </div>
    </section>

    <section class="product-list">
        @if (Model.Products?.Any() != true)
        {
            <div class="empty-state">
                @{
                    var hasActiveFilters = !string.IsNullOrEmpty(Model.Search) || Model.CategoryId.HasValue
                        || Model.SupplierId.HasValue || !string.IsNullOrEmpty(Model.ExpirationFilter);
                }
                @if (!hasActiveFilters)
                {
                    <p class="text-muted">No products available. Use the Configuration page to initialize the database with sample data.</p>
                }
                else
                {
                    <p class="text-muted">No products found matching your filters. Try adjusting your search or filters.</p>
                }
            </div>
        }
        else if (string.IsNullOrEmpty(Model.SortBy) || Model.SortBy == "Name")
        {
            @foreach (var group in Model.Products.GroupBy(p => p.Category?.Name ?? "Uncategorized"))
            {
                <div class="category-section">
                    <h3 class="category-header">@group.Key</h3>
                    <div class="product-grid">
                        @foreach (var p in group)
                        {
                            @await Html.PartialAsync("_ProductCard", p)
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <!-- Flat ranked list: category grouping would fragment the visible order for these sorts -->
            <div class="product-grid">
                @foreach (var p in Model.Products)
                {
                    @await Html.PartialAsync("_ProductCard", p)
                }
            </div>
        }

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="pagination-nav">
                <ul class="pagination">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="@Model.PageUrl(Model.CurrentPage - 1)">Previous</a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Model.PageUrl(i)">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="@Model.PageUrl(Model.CurrentPage + 1)">Next</a>
                    </li>
                </ul>
            </nav>
        }
    </section>

    <!-- Product Modal -->
    <div id="productModal" class="custom-modal" role="dialog" aria-hidden="true">
        <div class="custom-modal-dialog">
            <div class="custom-modal-content">
                <div class="custom-modal-header">
                    <h5 id="productModalTitle">Product Details</h5>
                    <button id="productModalClose" class="btn-close" aria-label="Close">×</button>
                </div>
                <div class="custom-modal-body" id="productModalBody">
                    <!-- Shipment details loaded dynamically -->
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/js/inventory.js"></script>
