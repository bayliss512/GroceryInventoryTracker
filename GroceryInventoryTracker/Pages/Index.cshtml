@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="inventory-page">
    <header class="page-header mb-4">
        <h1>Grocery Inventory Tracker</h1>
        <p class="lead">Employee Inventory Dashboard</p>
    </header>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">h
            <strong>Notice:</strong> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <section class="search-area mb-3">
        <form method="get" class="filter-form">
            <div class="filter-row">
                <select name="CategoryId" class="form-select" aria-label="Category" onchange="this.form.submit()">
                    <option value="">All Categories</option>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option>
                    }
                </select>
                <select name="SupplierId" class="form-select" aria-label="Supplier" onchange="this.form.submit()">
                    <option value="">All Suppliers</option>
                    @foreach (var s in Model.Suppliers)
                    {
                        <option value="@s.Id" selected="@(Model.SupplierId == s.Id)">@s.Name</option>
                    }
                </select>
                <select name="ExpirationFilter" class="form-select" aria-label="Expiration" onchange="this.form.submit()">
                    <option value="" selected="@(string.IsNullOrEmpty(Model.ExpirationFilter))">All Expirations</option>
                    <option value="ExpiringSoon" selected="@(Model.ExpirationFilter == "ExpiringSoon")">Expiring Soon (7 days)</option>
                    <option value="Expired" selected="@(Model.ExpirationFilter == "Expired")">Expired</option>
                </select>
                <select name="SortBy" class="form-select" aria-label="Sort by" onchange="this.form.submit()">
                    <option value="" selected="@(string.IsNullOrEmpty(Model.SortBy) || Model.SortBy == "Name")">Sort: Name</option>
                    <option value="Quantity" selected="@(Model.SortBy == "Quantity")">Sort: Quantity</option>
                    <option value="Expiration" selected="@(Model.SortBy == "Expiration")">Sort: Expiration</option>
                    <option value="RecentlyUpdated" selected="@(Model.SortBy == "RecentlyUpdated")">Sort: Recently Updated</option>
                </select>
            </div>
            <div class="input-group search-input-group">
                <input id="searchInput" name="Search" value="@Model.Search" type="text" class="form-control" placeholder="Search products or categories..." aria-label="Search" autocomplete="off" />
                <button class="btn btn-primary" type="submit">Search</button>
            </div>
        </form>
    </section>

    <div id="searchResults">
        @await Html.PartialAsync("_ProductResults", Model)
    </div>

    <!-- Product Modal -->
    <div id="productModal" class="custom-modal" role="dialog" aria-hidden="true">
        <div class="custom-modal-dialog">
            <div class="custom-modal-content">
                <div class="custom-modal-header">
                    <h5 id="productModalTitle">Product Details</h5>
                    <button id="productModalClose" class="btn-close" aria-label="Close">×</button>
                </div>
                <div class="custom-modal-body" id="productModalBody">
                    <!-- Shipment details loaded dynamically -->
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/qrcode-generator/qrcode.js"></script>
<!-- inventory.js is loaded globally from _Layout.cshtml -->

