@page
@model GroceryInventoryTracker.Pages.Shipments.CreateModel
@{
    ViewData["Title"] = "New Shipment";
}

<div class="shipment-form-page">
    <header class="page-header mb-4">
        <h1>New Shipment</h1>
    </header>

    <div class="card" style="max-width: 600px;">
        <div class="card-body">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Input.ProductId" class="form-label">Product</label>
                    <select asp-for="Input.ProductId" id="productSelect" class="form-select">
                        <option value="">-- Select a product --</option>
                        @foreach (var p in Model.ProductOptions)
                        {
                            <option value="@p.Id" data-perishable="@p.IsPerishable.ToString().ToLower()" selected="@(Model.Input.ProductId == p.Id)">@p.Name</option>
                        }
                    </select>
                    <span asp-validation-for="Input.ProductId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.SupplierId" class="form-label">Supplier (optional)</label>
                    <select asp-for="Input.SupplierId" asp-items="Model.SupplierOptions" class="form-select">
                        <option value="">-- None --</option>
                    </select>
                    <span asp-validation-for="Input.SupplierId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ShipmentNumber" class="form-label">Shipment Number</label>
                    <input asp-for="Input.ShipmentNumber" class="form-control" />
                    <span asp-validation-for="Input.ShipmentNumber" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3" id="expirationDateGroup">
                        <div id="expirationDateFields">
                            <label asp-for="Input.ExpirationDate" class="form-label">Expiration Date</label>
                            <input asp-for="Input.ExpirationDate" id="expirationDateInput" class="form-control" />
                            <span asp-validation-for="Input.ExpirationDate" class="text-danger"></span>
                        </div>
                        <p class="form-text mb-0" id="nonPerishableNote" style="display:none;">This product is marked non-perishable, so no expiration date is needed.</p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Input.Quantity" class="form-label">Quantity</label>
                        <input asp-for="Input.Quantity" type="number" min="1" class="form-control" />
                        <span asp-validation-for="Input.Quantity" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Location" class="form-label">Location</label>
                    <select asp-for="Input.Location" class="form-select">
                        <option value="InStorage">In Storage</option>
                        <option value="OnFloor">On Sales Floor</option>
                    </select>
                    <span asp-validation-for="Input.Location" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/shipmentForm.js" asp-append-version="true"></script>
}
