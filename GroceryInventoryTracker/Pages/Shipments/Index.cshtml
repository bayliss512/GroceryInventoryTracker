@page
@model GroceryInventoryTracker.Pages.Shipments.IndexModel
@{
    ViewData["Title"] = "Shipments";
}

<div class="shipments-page">
    <header class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h1>Shipments</h1>
            <p class="lead mb-0">Incoming inventory received from suppliers.</p>
        </div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-page="Create" class="btn btn-primary">New Shipment</a>
        }
    </header>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Success!</strong> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error:</strong> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="get" class="mb-3 d-flex gap-2" style="max-width: 400px;">
        <select name="ProductId" class="form-select" onchange="this.form.submit()">
            <option value="">All products</option>
            @foreach (var option in Model.ProductOptions)
            {
                <option value="@option.Value" selected="@(Model.ProductId?.ToString() == option.Value)">@option.Text</option>
            }
        </select>
    </form>

    <div class="card">
        <div class="card-header bg-light">
            <h5 class="mb-0">All Shipments (@Model.Shipments.Count)</h5>
        </div>
        <div class="card-body">
            @if (Model.Shipments.Count == 0)
            {
                <p class="text-muted mb-0">No shipments found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Shipment #</th>
                                <th>Product</th>
                                <th>Supplier</th>
                                <th>Expiration</th>
                                <th>Quantity</th>
                                <th>Location</th>
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <th class="text-end">Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var shipment in Model.Shipments)
                            {
                                <tr>
                                    <td>@shipment.ShipmentNumber</td>
                                    <td>@(shipment.Product?.Name ?? "—")</td>
                                    <td>@(shipment.Supplier?.Name ?? "—")</td>
                                    <td>@shipment.ExpirationDate.ToString("yyyy-MM-dd")</td>
                                    <td>@shipment.Quantity</td>
                                    <td>
                                        @if (shipment.Location == "OnFloor")
                                        {
                                            <span class="badge bg-success">On Sales Floor</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info">In Storage</span>
                                        }
                                    </td>
                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <td class="text-end">
                                            <div class="d-inline-flex gap-2">
                                                <a asp-page="Edit" asp-route-id="@shipment.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                                                <form method="post" asp-page-handler="Delete" asp-route-id="@shipment.Id"
                                                      onsubmit="return confirm('Delete shipment &quot;@shipment.ShipmentNumber&quot;? This cannot be undone.');">
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                                </form>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
