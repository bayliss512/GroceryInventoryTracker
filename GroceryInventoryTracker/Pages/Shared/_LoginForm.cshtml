<form method="post" asp-page="/Account" asp-page-handler="Login">
    <div class="mb-3">
        <label for="loginUsername" class="form-label">Username</label>
        <input id="loginUsername" name="Username" type="text" class="form-control" autocomplete="username" maxlength="64" required />
    </div>
    <div class="mb-3">
        <label for="loginPassword" class="form-label">Password</label>
        <input id="loginPassword" name="Password" type="password" class="form-control" autocomplete="current-password" required />
        <div class="form-text">Sign-up password requirement: at least 8 characters, including a letter and a number.</div>
    </div>
    <div class="alert alert-warning small py-2">
        <strong>Warning:</strong> Do not use a password you use anywhere else.
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Login</button>
        <button type="submit" asp-page="/Account" asp-page-handler="SignUp" class="btn btn-outline-primary">Sign Up</button>
    </div>
</form>
