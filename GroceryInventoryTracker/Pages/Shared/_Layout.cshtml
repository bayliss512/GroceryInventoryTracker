@inject IWebHostEnvironment WebHostEnvironment
@{
    var isDarkMode = User.FindFirst("Theme")?.Value == "dark";
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="@(isDarkMode ? "dark" : "light")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>@Html.Raw(GroceryInventoryTracker.Services.InlineCssCache.Get(WebHostEnvironment, "lib/bootstrap/dist/css/bootstrap.min.css"))</style>
    <style>@Html.Raw(GroceryInventoryTracker.Services.InlineCssCache.Get(WebHostEnvironment, "css/site.css"))</style>
    <link rel="stylesheet" href="~/GroceryInventoryTracker.styles.css" asp-append-version="true" />
    <title>@ViewData["Title"] - GroceryInventoryTracker</title>
    <script type="importmap"></script>
</head>
<body>
    <partial name="_IconSprite" />
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm bg-body-tertiary border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">GroceryInventoryTracker</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Dashboard">Dashboard</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="manageDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Manage
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="manageDropdown">
                                    <li><a class="dropdown-item" asp-page="/Products/Index">Products</a></li>
                                    <li><a class="dropdown-item" asp-page="/Shipments/Index">Shipments</a></li>
                                    @if (User.IsInRole("Administrator"))
                                    {
                                        <li><a class="dropdown-item" asp-page="/Categories/Index">Categories</a></li>
                                        <li><a class="dropdown-item" asp-page="/Suppliers/Index">Suppliers</a></li>
                                    }
                                </ul>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                        @if (User.IsInRole("Administrator"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Admin">Admin</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Audit/Index">Audit History</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Configuration">Configuration</a>
                            </li>
                        }
                    </ul>
                    <div class="navbar-login d-flex align-items-center gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var profileImage = User.FindFirst("ProfileImagePath")?.Value;
                            <a asp-page="/Settings" class="user-icon" title="User settings">
                                @if (!string.IsNullOrEmpty(profileImage))
                                {
                                    <img src="@profileImage" alt="@User.Identity.Name" class="user-avatar" />
                                }
                                else
                                {
                                    @Html.Raw(User.FindFirst("IconSvg")?.Value)
                                }
                            </a>
                            <a asp-page="/Settings" class="text-decoration-none">@User.Identity.Name</a>
                            <form method="post" asp-page="/Account" asp-page-handler="Logout" class="d-inline mb-0">
                                <button type="submit" class="btn btn-outline-secondary btn-sm">Log Out</button>
                            </form>
                        }
                        else
                        {
                            <button id="loginButton" type="button" class="btn btn-outline-primary btn-sm">Login</button>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @if (User.Identity?.IsAuthenticated != true)
    {
        <!-- Login Modal -->
        <div id="loginModal" class="custom-modal" role="dialog" aria-hidden="true">
            <div class="custom-modal-dialog">
                <div class="custom-modal-content">
                    <div class="custom-modal-header">
                        <h5 id="loginModalTitle">Login</h5>
                        <button id="loginModalClose" class="btn-close" aria-label="Close">&times;</button>
                    </div>
                    <div class="custom-modal-body">
                        <partial name="_LoginForm" />
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Confirm Action Modal -->
    <div id="confirmModal" class="custom-modal" role="dialog" aria-hidden="true">
        <div class="custom-modal-dialog confirm-modal-dialog">
            <div class="custom-modal-content">
                <div class="custom-modal-header">
                    <h5 id="confirmModalTitle">Please confirm</h5>
                    <button id="confirmModalClose" type="button" class="btn-close" aria-label="Close">&times;</button>
                </div>
                <div class="custom-modal-body">
                    <div class="d-flex align-items-start gap-3">
                        <svg class="icon icon-lg text-danger"><use href="#icon-warning"></use></svg>
                        <p id="confirmModalMessage" class="mb-0"></p>
                    </div>
                </div>
                <div class="d-flex justify-content-end gap-2 p-3 border-top">
                    <button id="confirmModalCancel" type="button" class="btn btn-outline-secondary">Cancel</button>
                    <button id="confirmModalAccept" type="button" class="btn btn-danger">Confirm</button>
                </div>
            </div>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - GroceryInventoryTracker - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <!-- Populated just before window.print() is called and hidden otherwise; @@media print
         hides every other direct child of body so only this prints. -->
    <div id="qrPrintArea"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/inventory.js" asp-append-version="true"></script>
    <script src="~/js/login.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
